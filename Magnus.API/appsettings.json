{
  "ConnectionStrings": {
    "DefaultConnection": "__SET_IN_ENV__"
  },
  "JwtSettings": {
    "Issuer": "MagnusAPI",
    "Audience": "MagnusAPIUsers",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7,
    "Secret": "__SET_IN_ENV__"
  },
  "SeedSettings": {
